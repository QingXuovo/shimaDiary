<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shima.diary.mapper.TaskMapper">

    <resultMap id="TaskResultMap" type="com.shima.diary.entity.Task">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="description" column="description"/>
        <result property="priority" column="priority"/>
        <result property="status" column="status"/>
        <result property="category" column="category"/>
        <result property="dueDate" column="due_date"/>
        <result property="reminderTime" column="reminder_time"/>
        <result property="estimatedTime" column="estimated_time"/>
        <result property="actualTime" column="actual_time"/>
        <result property="progress" column="progress"/>
        <result property="parentId" column="parent_id"/>
        <result property="sortOrder" column="sort_order"/>
        <result property="userId" column="user_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="completeTime" column="complete_time"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectByParentId" resultMap="TaskResultMap">
        SELECT * FROM task
        WHERE parent_id = #{parentId}
          AND deleted = 0
        ORDER BY sort_order ASC, create_time ASC
    </select>

    <select id="selectTodayDue" resultMap="TaskResultMap">
        SELECT * FROM task
        WHERE user_id = #{userId}
          AND due_date = #{today}
          AND status IN (0, 1)
          AND deleted = 0
        ORDER BY priority ASC, create_time ASC
    </select>

    <select id="selectOverdue" resultMap="TaskResultMap">
        SELECT * FROM task
        WHERE user_id = #{userId}
          AND due_date &lt; #{today}
          AND status IN (0, 1)
          AND deleted = 0
        ORDER BY due_date ASC, priority ASC
    </select>

</mapper>
