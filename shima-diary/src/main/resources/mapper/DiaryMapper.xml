<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shima.diary.mapper.DiaryMapper">

    <resultMap id="DiaryResultMap" type="com.shima.diary.entity.Diary">
        <id property="id" column="id"/>
        <result property="title" column="title"/>
        <result property="content" column="content"/>
        <result property="mood" column="mood"/>
        <result property="weather" column="weather"/>
        <result property="location" column="location"/>
        <result property="tags" column="tags"/>
        <result property="diaryDate" column="diary_date"/>
        <result property="userId" column="user_id"/>
        <result property="createTime" column="create_time"/>
        <result property="updateTime" column="update_time"/>
        <result property="deleted" column="deleted"/>
    </resultMap>

    <select id="selectByDateRange" resultMap="DiaryResultMap">
        SELECT * FROM diary
        WHERE user_id = #{userId}
          AND diary_date BETWEEN #{startDate} AND #{endDate}
          AND deleted = 0
        ORDER BY diary_date DESC, create_time DESC
    </select>

    <select id="countByMood" resultType="int">
        SELECT COUNT(*) FROM diary
        WHERE user_id = #{userId}
          AND mood = #{mood}
          AND deleted = 0
    </select>

</mapper>
