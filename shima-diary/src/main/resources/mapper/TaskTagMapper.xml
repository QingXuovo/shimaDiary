<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.shima.diary.mapper.TaskTagMapper">

    <resultMap id="TaskTagResultMap" type="com.shima.diary.entity.TaskTag">
        <id property="id" column="id"/>
        <result property="taskId" column="task_id"/>
        <result property="tagName" column="tag_name"/>
        <result property="tagColor" column="tag_color"/>
        <result property="createTime" column="create_time"/>
    </resultMap>

    <select id="selectByTaskId" resultMap="TaskTagResultMap">
        SELECT * FROM task_tag
        WHERE task_id = #{taskId}
        ORDER BY create_time ASC
    </select>

</mapper>
